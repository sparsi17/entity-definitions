{
  "name": "GCP API Gateway gateway",
  "description": null,
  "permissions": "PUBLIC_READ_WRITE",
  "pages": [
    {
      "name": "GCP API Gateway gateway",
      "description": null,
      "widgets": [
        {
          "title": "Request Count",
          "layout": { "column": 1, "row": 1, "width": 4, "height": 3 },
          "linkedEntityGuids": null,
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM Metric SELECT sum(gcp.apigateway.http.request_count) AS 'Requests' WHERE entity.guid = '{{entity.id}}' TIMESERIES AUTO"
              }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "Error Rate",
          "layout": { "column": 5, "row": 1, "width": 4, "height": 3 },
          "linkedEntityGuids": null,
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM Metric SELECT filter(sum(gcp.apigateway.http.request_count), WHERE response_code_class IN ('4xx', '5xx')) * 100 / sum(gcp.apigateway.http.request_count) AS 'Error Rate %' WHERE entity.guid = '{{entity.id}}' TIMESERIES AUTO"
              }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "Request Latency (avg ms)",
          "layout": { "column": 9, "row": 1, "width": 4, "height": 3 },
          "linkedEntityGuids": null,
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM Metric SELECT average(gcp.apigateway.http.request_latencies) * 1000 AS 'Latency (ms)' WHERE entity.guid = '{{entity.id}}' TIMESERIES AUTO"
              }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "Requests by Response Code Class",
          "layout": { "column": 1, "row": 4, "width": 6, "height": 3 },
          "linkedEntityGuids": null,
          "visualization": { "id": "viz.bar" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM Metric SELECT sum(gcp.apigateway.http.request_count) AS 'Requests' WHERE entity.guid = '{{entity.id}}' FACET response_code_class"
              }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "Request Sizes (avg bytes)",
          "layout": { "column": 7, "row": 4, "width": 6, "height": 3 },
          "linkedEntityGuids": null,
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM Metric SELECT average(gcp.apigateway.http.request_sizes) AS 'Avg Request Size (bytes)' WHERE entity.guid = '{{entity.id}}' TIMESERIES AUTO"
              }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "Response Sizes (avg bytes)",
          "layout": { "column": 1, "row": 7, "width": 6, "height": 3 },
          "linkedEntityGuids": null,
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM Metric SELECT average(gcp.apigateway.http.response_sizes) AS 'Avg Response Size (bytes)' WHERE entity.guid = '{{entity.id}}' TIMESERIES AUTO"
              }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "Requests by Backend Service",
          "layout": { "column": 7, "row": 7, "width": 6, "height": 3 },
          "linkedEntityGuids": null,
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM Metric SELECT sum(gcp.apigateway.http.request_count) AS 'Requests' WHERE entity.guid = '{{entity.id}}' TIMESERIES AUTO FACET backend_service"
              }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        }
      ]
    }
  ]
}
