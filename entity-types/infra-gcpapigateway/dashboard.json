{
  "name": "GCP API Gateway gateway",
  "description": null,
  "pages": [
    {
      "name": "GCP API Gateway gateway",
      "description": null,
      "widgets": [
        {
          "title": "Request Count",
          "layout": { "column": 1, "row": 1, "width": 6, "height": 3 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "FROM Metric SELECT sum(gcp.apigateway.proxy.request_count) AS 'Requests' WHERE entity.guid = '{{entity.id}}' TIMESERIES AUTO"
              }
            ]
          }
        },
        {
          "title": "Error Rate",
          "layout": { "column": 7, "row": 1, "width": 6, "height": 3 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "FROM Metric SELECT filter(sum(gcp.apigateway.proxy.request_count), WHERE response_code_class IN ('4xx', '5xx')) * 100 / sum(gcp.apigateway.proxy.request_count) AS 'Error Rate %' WHERE entity.guid = '{{entity.id}}' TIMESERIES AUTO"
              }
            ]
          }
        },
        {
          "title": "Requests by Response Code Class",
          "layout": { "column": 1, "row": 4, "width": 6, "height": 3 },
          "visualization": { "id": "viz.bar" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "FROM Metric SELECT sum(gcp.apigateway.proxy.request_count) AS 'Requests' WHERE entity.guid = '{{entity.id}}' FACET response_code_class"
              }
            ]
          }
        },
        {
          "title": "Requests by API Config",
          "layout": { "column": 7, "row": 4, "width": 6, "height": 3 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "FROM Metric SELECT sum(gcp.apigateway.proxy.request_count) AS 'Requests' WHERE entity.guid = '{{entity.id}}' TIMESERIES AUTO FACET api_config"
              }
            ]
          }
        }
      ]
    }
  ]
}
