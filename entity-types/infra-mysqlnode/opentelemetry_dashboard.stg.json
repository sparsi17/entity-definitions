        {
          "title": "Query Performance",
          "layout": { "column": 1, "row": 28, "width": 12, "height": 1 },
          "visualization": { "id": "viz.markdown" },
          "rawConfiguration": {
            "text": "## Query Performance\nData below comes from the receiver's `db.server.top_query` and `db.server.query_sample` log events. These are development-stage events and are **disabled by default** — enable `events.db.server.top_query` / `events.db.server.query_sample` in the mysqlreceiver configuration to populate these widgets."
          }
        },
        {
          "title": "Top queries by total execution time",
          "layout": { "column": 1, "row": 29, "width": 6, "height": 3 },
          "visualization": { "id": "viz.bar" },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "nrqlQueries": [
              { "accountId": 0, "query": "SELECT latest(`mysql.events_statements_summary_by_digest.sum_timer_wait`) AS 'Total time (s)' FROM Log WHERE `event.name` = 'db.server.top_query' FACET `db.query.text` LIMIT 20" }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "Top queries by execution count",
          "layout": { "column": 7, "row": 29, "width": 6, "height": 3 },
          "visualization": { "id": "viz.bar" },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "nrqlQueries": [
              { "accountId": 0, "query": "SELECT latest(`mysql.events_statements_summary_by_digest.count_star`) AS 'Executions' FROM Log WHERE `event.name` = 'db.server.top_query' FACET `db.query.text` LIMIT 20" }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "Top queries (detail)",
          "layout": { "column": 1, "row": 32, "width": 12, "height": 3 },
          "visualization": { "id": "viz.table" },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "nrqlQueries": [
              { "accountId": 0, "query": "SELECT latest(`db.query.text`) AS 'Query', latest(`mysql.events_statements_summary_by_digest.count_star`) AS 'Executions', latest(`mysql.events_statements_summary_by_digest.sum_timer_wait`) AS 'Total time (s)' FROM Log WHERE `event.name` = 'db.server.top_query' FACET `mysql.events_statements_summary_by_digest.digest` LIMIT 50" }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "Sampled running queries",
          "layout": { "column": 1, "row": 35, "width": 12, "height": 3 },
          "visualization": { "id": "viz.table" },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "nrqlQueries": [
              { "accountId": 0, "query": "SELECT latest(`db.query.text`) AS 'Query', latest(`user.name`) AS 'User', latest(`db.namespace`) AS 'Database', latest(`mysql.events_statements_current.timer_wait`) AS 'Elapsed (s)' FROM Log WHERE `event.name` = 'db.server.query_sample' FACET `mysql.event_id` LIMIT 50" }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "Sampled queries by user",
          "layout": { "column": 1, "row": 38, "width": 6, "height": 3 },
          "visualization": { "id": "viz.pie" },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "legend": { "enabled": true },
            "nrqlQueries": [
              { "accountId": 0, "query": "SELECT count(*) FROM Log WHERE `event.name` = 'db.server.query_sample' FACET `user.name`" }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "Sampled queries by database",
          "layout": { "column": 7, "row": 38, "width": 6, "height": 3 },
          "visualization": { "id": "viz.pie" },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "legend": { "enabled": true },
            "nrqlQueries": [
              { "accountId": 0, "query": "SELECT count(*) FROM Log WHERE `event.name` = 'db.server.query_sample' FACET `db.namespace`" }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        }
