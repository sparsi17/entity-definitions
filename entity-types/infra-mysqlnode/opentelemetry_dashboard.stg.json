{
  "name": "MySQL - OpenTelemetry",
  "description": "MySQL monitoring for data sent via the OpenTelemetry Collector mysqlreceiver. Widgets titled 'requires enabling' use metrics that are disabled by default in the receiver and must be turned on in the collector configuration.",
  "pages": [
    {
      "name": "MySQL - OpenTelemetry",
      "description": "Overview and query performance for a MySQL instance instrumented with the OpenTelemetry mysqlreceiver.",
      "widgets": [
        {
          "title": "Threads by state",
          "layout": { "column": 1, "row": 1, "width": 4, "height": 3 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "legend": { "enabled": true },
            "nrqlQueries": [
              { "accountId": 0, "query": "SELECT latest(`mysql.threads`) FROM Metric FACET kind TIMESERIES AUTO" }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "Connection attempts (requires enabling)",
          "layout": { "column": 5, "row": 1, "width": 4, "height": 3 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              { "accountId": 0, "query": "SELECT average(`mysql.connection.count`) AS 'Connection attempts' FROM Metric TIMESERIES AUTO" }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
